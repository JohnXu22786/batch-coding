{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "deny",
    "edit": "deny",
    "glob": "deny",
    "grep": "deny",
    "bash": "deny",
    "webfetch": "deny",
    "task": "deny",
    "external_directory": {
      "*": "allow"
    }
  },
  "mcp": {
    "test_checklist": {
      "type": "local",
      "command": [
        "test-checklist-mcp"
      ],
      "enabled": false
    },
    "batch-prompt": {
      "type": "local",
      "command": [
        "node",
        "D:\\Administrator\\Desktop\\OpenCode Batch\\.opencode\\mcp\\batch-prompt\\index.js"
      ],
      "enabled": true,
      "timeout": 86400000
    }
  },
  "experimental": {
    "mcp_timeout": 86400000
  },
  "default_agent": "batch",
  "agent": {
    "batch": {
      "mode": "primary",
      "description": "Batch dispatcher for multiple modification requests",
    }
  }
}
