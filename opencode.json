{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "*": "allow"
    }
  },
  "mcp": {
    "test_checklist": {
      "type": "local",
      "command": [
        "test-checklist-mcp"
      ],
      "enabled": true
    },
    "batch-prompt": {
      "type": "local",
      "command": [
        "node",
        ".opencode/mcp/batch-prompt/index.js"
      ],
      "enabled": true,
      "timeout": 86400000
    }
  },
  "experimental": {
    "mcp_timeout": 86400000
  },
  "default_agent": "batch",
  "agent": {
    "coding": {
      "mode": "primary",
      "description": "Project coding workflow with 6 phases"
    },
    "reviewer": {
      "mode": "subagent",
      "description": "Review code changes for correctness, scope, simplicity, and test coverage"
    },
    "release": {
      "description": "Git Release manager using Trunk-Based + Release Branch model. Handles branching, tagging, CI checks, and cleanup.",
      "mode": "primary"
    },
    "batch": {
      "mode": "primary",
      "description": "Batch dispatcher for multiple modification requests"
    }
  }
}
